---
import Base from '../layouts/Base.astro';
---

<Base title="recall">
<main class="home" id="homeApp">
  <div class="home-top">
    <button class="icon-btn" onclick="toggleTheme()" aria-label="Toggle theme" title="Toggle theme (t)">
      <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path></svg>
      <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path></svg>
    </button>
  </div>

  <header class="home-hero">
    <h1 class="home-mark">recall<span class="dot">.</span></h1>
    <p class="home-sub">A method for learning and revision by question — every concept distilled from its full source into one clear answer.</p>
    <p class="home-subject">Pick a subject — <b>Q&amp;A</b> to revise, <b>Book</b> to read.</p>
  </header>

  <div class="home-links" id="techList"></div>

  <footer class="home-foot">
    <div class="foot-hint">Press <span class="kbd">t</span> to switch light / dark · <span class="kbd">⌘K</span> to search everything.</div>
    <div class="foot-author">
      <span class="fa-by">Made by <b>Javlonbek</b></span>
      <span class="fa-links">
        <a href="https://github.com/Javlonbk" target="_blank" rel="noopener" title="GitHub">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.88-.01-1.73-2.78.62-3.37-1.37-3.37-1.37-.46-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05a9.36 9.36 0 0 1 5 0c1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.6.69.49A10.26 10.26 0 0 0 22 12.25C22 6.58 17.52 2 12 2z"></path></svg>
          <span>GitHub</span>
        </a>
        <a href="mailto:javlonbkswe@gmail.com" title="Email">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="M3 7l9 6 9-6"></path></svg>
          <span>Email</span>
        </a>
      </span>
    </div>
  </footer>
</main>
</Base>
